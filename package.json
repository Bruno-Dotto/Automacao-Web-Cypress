{
  "name": "automacao-web-cypress",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
"scripts": {
  "cy:open": "cypress open",
  "cy:run": "cypress run",
  "smoke": "cypress run --expose grepTags=@smoke,grepFilterSpecs=true,grepOmitFiltered=true",
  "regression": "cypress run",
  "clean-report": "node -e \"require('fs').rmSync('cypress/reports',{recursive:true,force:true});require('fs').mkdirSync('cypress/reports',{recursive:true})\"",
  "merge-report": "mochawesome-merge \"cypress/reports/mochawesome*.json\" -o cypress/reports/report.json",
  "generate-report": "marge cypress/reports/report.json --reportDir cypress/reports --reportFilename index --inline",
  "report": "npm run merge-report && npm run generate-report",
  "smoke-report": "npm run clean-report && npm run smoke && npm run report"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "cypress": "^15.17.0"
  },
  "devDependencies": {
    "@cypress/grep": "^6.0.2",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
